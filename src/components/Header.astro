---
import HeaderLink from './HeaderLink.astro';
import { SITE_TITLE } from '../consts';
---

<header>
	<nav>
		<h2>
			<a href="/" aria-label={SITE_TITLE}>
				<img src="/favicon.svg" alt="" aria-hidden="true" width="32" height="32" />
				<span>{SITE_TITLE}</span>
				
			</a>
		</h2>
		<div class="internal-links">
			<HeaderLink href="/">Start</HeaderLink>
			<HeaderLink href="/blog">Blog</HeaderLink>
			<HeaderLink href="/about">Über uns</HeaderLink>
		</div>
		<div class="social-links">
			<a href="/rss.xml">
				<span class="sr-only">RSS-Feed abonnieren</span>
				<svg viewBox="0 0 16 16" aria-hidden="true" width="32" height="32">
					<path
						fill="currentColor"
						d="M2 0a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V2a2 2 0 0 0-2-2H2zm1.5 2.5c3.314 0 6 2.686 6 6h-1.5c0-2.485-2.015-4.5-4.5-4.5V2.5zm0 3c1.657 0 3 1.343 3 3H5c0-.828-.672-1.5-1.5-1.5V5.5zM3.5 9a1.5 1.5 0 1 1 0 3 1.5 1.5 0 0 1 0-3z"
					/>
				</svg>
			</a>
		</div>
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: white;
		box-shadow: 0 2px 8px rgba(var(--black), 5%);
	}
	h2 {
		margin: 0;
		font-size: 1em;
	}

	h2 a,
	h2 a.active {
		text-decoration: none;
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
	}
	h2 img {
		display: block;
		width: 32px;
		height: 32px;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
	}
	nav a {
		padding: 1em 0.5em;
		color: var(--black);
		border-bottom: 4px solid transparent;
		text-decoration: none;
	}
	nav a.active {
		text-decoration: none;
		border-bottom-color: var(--accent);
	}
	.social-links,
	.social-links a {
		display: flex;
	}
	@media (max-width: 720px) {
		.social-links {
			display: none;
		}
	}
</style>
