---
import type { CollectionEntry } from 'astro:content';
import { Picture } from 'astro:assets';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage } = Astro.props;
---

<html lang="de">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			main {
				width: calc(100% - 2em);
				max-width: 100%;
				margin: 0;
			}
			article {
				display: flex;
				flex-direction: row-reverse;
				align-items: flex-start;
				gap: 2em;
				padding: 2em;
				max-width: 1200px;
				margin: 0 auto;
			}
			.hero-image {
				flex: 0 0 40%;
				position: sticky;
				top: 2em;
			}
			.hero-image img {
				display: block;
				width: 100%;
				border-radius: 12px;
				box-shadow: var(--box-shadow);
				aspect-ratio: 210 / 297;
				object-fit: cover;
				object-position: center;
			}
			.prose {
				flex: 1 1 0;
				min-width: 0;
				padding: 1em 0;
				color: rgb(var(--gray-dark));
			}
			.title {
				margin-bottom: 1em;
				padding: 1em 0;
				line-height: 1;
			}
			.title h1 {
				margin: 0 0 0.5em 0;
			}
			.date {
				margin-bottom: 0.5em;
				color: rgb(var(--gray));
			}
			.last-updated-on {
				font-style: italic;
			}
			@media (max-width: 720px) {
				article {
					flex-direction: column;
					padding: 1em;
					gap: 1em;
				}
				.hero-image {
					position: static;
					flex: none;
					width: 100%;
				}
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="hero-image">
					{heroImage && <Picture width={1020} height={1443} src={heroImage} formats={['avif', 'webp']} alt="" loading="eager" fetchpriority="high" />}
				</div>
				<div class="prose">
					<div class="title">
						<div class="date">
							<FormattedDate date={pubDate} />
							{
								updatedDate && (
									<div class="last-updated-on">
										Zuletzt aktualisiert am <FormattedDate date={updatedDate} />
									</div>
								)
							}
						</div>
						<h1>{title}</h1>
						<hr />
					</div>
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
