---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="de">
	<head>
		<BaseHead title={`404 – ${SITE_TITLE}`} description="Seite nicht gefunden" />
		<style>
			main {
				text-align: center;
				padding: 4rem 1rem;
			}
			h1 {
				font-size: 6rem;
				margin: 0;
				line-height: 1;
				color: rgb(var(--accent));
			}
			h2 {
				margin: 0.5rem 0 1.5rem;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<h1>404</h1>
			<h2>Seite nicht gefunden</h2>
			<p>Diese Seite existiert leider nicht. Vielleicht hilft ein Blick in die <a href="/tastings">Tastings</a>?</p>
		</main>
		<Footer />
	</body>
</html>
